{
  "name": "backend-template",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "type": "module",

  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch ./src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",

    "db:seed": "cross-env NODE_ENV=development prisma db seed",
    "db:migrate": "cross-env NODE_ENV=development prisma migrate dev --name auto-migration",
    "db:push": "cross-env NODE_ENV=development prisma db push",
    "db:generate": "cross-env NODE_ENV=development prisma generate"
  },

  "packageManager": "pnpm@10.14.0",

  "dependencies": {
    "@prisma/client": "6.16.1",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.11.4",
    "dotenv": "^17.2.2",
    "jsonwebtoken": "^9.0.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "zod": "4.3.6"
  },

  "devDependencies": {
    "prisma": "6.16.1",
    "typescript": "^5.9.2",
    "tsx": "^4.20.5",
    "@types/node": "^24.3.1"
  }
}
